{
  "name": "@your-org/ai-hub",
  "version": "1.0.0",
  "description": "AI Skill/Command/MCP distribution platform for enterprise teams",
  "main": "dist/index.js",
  "bin": {
    "ai-hub": "dist/index.js",
    "scan-secrets": "dist/scan-secrets.js"
  },
  "scripts": {
    "build": "tsc && npm run build:scan-secrets",
    "build:scan-secrets": "npm --prefix tools/scan-secrets run build",
    "build:all": "tsc && npm run build:scan-secrets",
    "dev": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:ci": "npm run build && jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xjtuwangke/ai-hub.git"
  },
  "bugs": {
    "url": "https://github.com/xjtuwangke/ai-hub/issues"
  },
  "homepage": "https://github.com/xjtuwangke/ai-hub#readme",
  "files": [
    "dist/",
    "tools/scan-secrets/dist/",
    "skills/",
    "commands/",
    "mcp/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "secret-scan-rules.example.yaml",
    "secret-scan-plugin.example.js"
  ],
  "keywords": [
    "ai",
    "agent",
    "skill",
    "command",
    "mcp",
    "opencode",
    "copilot",
    "codex",
    "enterprise",
    "distribution"
  ],
  "author": "Platform Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "http-proxy-agent": "^5.0.0",
    "https-proxy-agent": "^5.0.1",
    "inquirer": "^8.2.6",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1",
    "semver": "^7.6.2",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.0",
    "@types/node-fetch": "^2.6.13",
    "@types/semver": "^7.5.8",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
